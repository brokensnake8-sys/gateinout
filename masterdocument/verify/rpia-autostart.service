[Unit]
Description=RPi A - Fingerprint Gate System
After=network.target

[Service]
Type=simple
User=yareuun
WorkingDirectory=/home/yareuun/verify
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/yareuun/.Xauthority
ExecStart=/bin/bash /home/yareuun/verify/autostart.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
